{
  "manifest_version": 3,
  "name": "Tabio",
  "version": "6.0.0",
  "description": "Export tabs to text. Import text to tabs. Save sessions. Clean links.",
  "permissions": [
    "tabs", "windows", "tabGroups",
    "clipboardWrite", "clipboardRead",
    "storage"
  ],
  "optional_permissions": ["system.display"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
